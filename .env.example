# Required: Telegram bot token from BotFather.
TELEGRAM_BOT_TOKEN=

# Required: Fernet key used to encrypt stored survey data.
# Generate with:
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Optional: storage directory for the SQLite DB and encrypted voice files.
# Defaults to /home/ubuntu/kremenchuk for compatibility with the current deployment.
# UKRAINABILITY_STORAGE_DIR=/home/ubuntu/kremenchuk

# Optional: legacy credentials file with lines like:
# export TELEGRAM_BOT_TOKEN="..."
# export ENCRYPTION_KEY="..."
# Defaults to /home/ubuntu/kremenchuk/secure/credentials
# UKRAINABILITY_CREDENTIALS_FILE=/home/ubuntu/kremenchuk/secure/credentials
